{
  "kind": "collectionType",
  "collectionName": "skill_categories",
  "info": {
    "singularName": "skill-category",
    "pluralName": "skill-categories",
    "displayName": "Skill Category"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "skills": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::skill.skill",
      "mappedBy": "category"
    }
  }
}